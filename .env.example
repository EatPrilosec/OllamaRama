# OllamaRama Configuration
# Copy this file to .env and update the values as needed

# Port configuration for Ollama instances
# Format: comma-separated list of individual ports and/or port ranges
# Examples:
#   - Single ports: "11434,11435,11436"
#   - Port ranges: "11430-11433"
#   - Mixed: "11430-11433,11435,11440-11442"
OLLAMA_PORTS=11430-11433,11435

# Server configuration
HOST=0.0.0.0
PORT=8000

# Development mode (set to True for detailed logging)
DEBUG=False
